# ----------------------------------------------------------------------------
# cHackerBlog runtime configuration. Copy to `.env` and adjust.
# All values are validated by src/lib/env.ts (zod). Invalid env fails fast.
# ----------------------------------------------------------------------------

# --- Core ---
NODE_ENV=development
APP_URL=http://localhost:3000

# --- Logging ---
# Log level: trace, debug, info, warn, error, silent
# Defaults: trace for development, error for production
# Override with LOG_LEVEL to set a specific level
LOG_LEVEL=
# Log to console (true/false, default: true)
LOG_TO_CONSOLE=true
# Log to file (true/false, default: true)
LOG_TO_FILE=true
# Log directory for file output (default: ./logs)
LOG_DIR=./logs
# Log filename (default: app.log)
LOG_FILE=app.log

# --- Database ---
# Local development uses SQLite; production uses PostgreSQL.
# Set DATABASE_PROVIDER to "sqlite" or "postgresql" (must match prisma generate).
DATABASE_PROVIDER=sqlite
DATABASE_URL="file:./dev.db"
# Example production value:
# DATABASE_PROVIDER=postgresql
# DATABASE_URL="postgresql://user:pass@host:5432/chackerblog?schema=public"

# --- Admin auth ---
# Plaintext is hashed on first boot if ADMIN_PASSWORD_HASH is empty.
# Prefer setting ADMIN_PASSWORD_HASH (bcrypt) in production.
ADMIN_PASSWORD=changeme
ADMIN_PASSWORD_HASH=
# Secret used to sign the admin session cookie.
SESSION_SECRET=replace-with-a-long-random-string

# --- Redis (ioredis) ---
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=chb:

# --- Cache durations (seconds) ---
CACHE_TTL_GLOBAL_SETTINGS=300
CACHE_TTL_ARTICLE=120
CACHE_TTL_FEED=30

# --- Rate limiting ---
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=100
# When true, trust Cloudflare's CF-Connecting-IP header for the real client IP.
TRUST_CLOUDFLARE=true

# --- Feed / infinite scroll ---
# How many articles to fetch per page (prefetched in advance for performance).
FEED_PAGE_SIZE=5
# How many pages to prefetch ahead of the scroll position.
FEED_PREFETCH_PAGES=1
# How many leading articles render fully expanded at the top of the feed.
FEED_EXPANDED_COUNT=1
# Set to true to expand ALL articles in the feed (overrides FEED_EXPANDED_COUNT)
FEED_EXPAND_ALL=false
# How many characters to show in feed preview (truncated from full content)
FEED_PREVIEW_CHARS=200
# Feed expansion ratio (0-1): 1 = full screen like Medium, 0.5 = half screen
FEED_EXPANSION_RATIO=0.5

# --- Theme defaults (overridable in SiteSettings via the setup screen) ---
# RGB triplets ("r g b"). Default below is the green-on-black hacker terminal.
THEME_BG=0 0 0
THEME_FG=51 255 102
THEME_ACCENT=0 255 153
THEME_MUTED=20 80 40
THEME_CARD=8 12 8
THEME_BORDER=20 60 30
THEME_FONT_BODY="'JetBrains Mono', ui-monospace, monospace"
THEME_FONT_HEADING="'JetBrains Mono', ui-monospace, monospace"
THEME_FONT_MONO="'JetBrains Mono', ui-monospace, monospace"

# --- Mailer (nodemailer SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="cHackerBlog <noreply@example.com>"

# --- IP geolocation provider ---
# Endpoint receiving {ip} substitution, e.g. https://ipapi.co/{ip}/json/
IPGEO_ENDPOINT=https://ipapi.co/{ip}/json/

# --- Social auto-posting (optional; enabled if creds present) ---
SOCIAL_AUTOPOST_ENABLED=false
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=

# --- Uploads ---
UPLOAD_DIR=./public/uploads
UPLOAD_MAX_BYTES=5242880

# --- Comments ---
# Set to false to disable commenting across the site
COMMENTS_ENABLED=true
