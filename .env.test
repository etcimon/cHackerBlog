# Test environment configuration
NODE_ENV=development
APP_URL=http://localhost:3000

# Test database (separate from development)
DATABASE_PROVIDER=sqlite
DATABASE_URL="file:./test.sqlite"

# Admin auth for tests
ADMIN_PASSWORD=changeme
ADMIN_PASSWORD_HASH=
SESSION_SECRET=test-secret-for-testing-only

# Redis (use in-memory fallback for tests)
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=test:

# Cache durations (shorter for tests)
CACHE_TTL_GLOBAL_SETTINGS=10
CACHE_TTL_ARTICLE=5
CACHE_TTL_FEED=2

# Rate limiting (disabled for tests)
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=1000
TRUST_CLOUDFLARE=false

# Feed settings
FEED_PAGE_SIZE=5
FEED_PREFETCH_PAGES=1
FEED_EXPANDED_COUNT=1
FEED_EXPAND_ALL=false
FEED_PREVIEW_CHARS=200
FEED_EXPANSION_RATIO=0.5

# Theme defaults
THEME_BG=0 0 0
THEME_FG=51 255 102
THEME_ACCENT=0 255 153
THEME_MUTED=20 80 40
THEME_CARD=8 12 8
THEME_BORDER=20 60 30
THEME_FONT_BODY="'JetBrains Mono', ui-monospace, monospace"
THEME_FONT_HEADING="'JetBrains Mono', ui-monospace, monospace"
THEME_FONT_MONO="'JetBrains Mono', ui-monospace, monospace"

# Mailer (disabled for tests)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Test <test@example.com>"

# IP geolocation (disabled for tests)
IPGEO_ENDPOINT=

# Social auto-posting (disabled for tests)
SOCIAL_AUTOPOST_ENABLED=false
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=

# Uploads
UPLOAD_DIR=./public/test-uploads
UPLOAD_MAX_BYTES=5242880

# Comments (enabled for tests)
COMMENTS_ENABLED=true

# Logging (verbose for tests)
LOG_LEVEL=trace
LOG_TO_CONSOLE=true
LOG_TO_FILE=false
LOG_DIR=./test-logs
LOG_FILE=test.log
