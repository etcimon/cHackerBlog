{
  "name": "chackerblog",
  "version": "0.1.0",
  "private": true,
  "description": "Cimon's Hacker Blog (cHackerBlog) — a themable, API-interactive, infinite-scroll blogging platform.",
  "homepage": "https://github.com/etcimon/chackerblog",
  "repository": {
    "type": "git",
    "url": "https://github.com/etcimon/chackerblog"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "bun run prisma/seed.ts",
    "db:studio": "prisma studio",
    "test": "jest",
    "test:verbose": "jest --verbose",
    "test:coverage": "jest --coverage",
    "test:ci": "bun run typecheck && bun run build && bun run test",
    "test:e2e": "jest tests/e2e",
    "test:e2e:verbose": "jest tests/e2e --verbose",
    "test:unit": "jest tests/unit",
    "test:unit:verbose": "jest tests/unit --verbose",
    "screenshots": "bun run scripts/screenshots.ts",
    "test:db:setup": "bun run scripts/setup-test-db.ts"
  },
  "prisma": {
    "seed": "bun run prisma/seed.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@prisma/client": "^5.18.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "ioredis": "^5.4.1",
    "lucide-react": "^0.427.0",
    "marked": "^12.0.1",
    "next": "^14.2.5",
    "nodemailer": "^6.9.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.52.2",
    "turndown": "^7.1.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.12",
    "@types/marked": "^6.0.0",
    "@types/node": "^20.14.15",
    "@types/nodemailer": "^6.4.15",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "jest": "^29.7.0",
    "postcss": "^8.4.41",
    "prisma": "^5.18.0",
    "puppeteer": "^23.1.1",
    "sass": "^1.101.0",
    "tailwindcss": "^3.4.9",
    "ts-jest": "^29.2.5",
    "typescript": "^5.5.4"
  }
}
